---
import '../styles/global.css'
import Layout from "../layouts/Layout.astro";
import AppHeader from '../components/Header.astro';
import AppFooter from '../components/Footer.astro';

import Resume from '../assets/ProfessionalSummary/Resume.pdf'
import Cbar from '../assets/ProfessionalSummary/CBAR_Internship.pdf'
import FinalDemo from '../assets/ProfessionalSummary/FinalDemo_LPWest.pdf'
import GallanoLP from '../assets/ProfessionalSummary/Gallano_LP(FinalDemonstration-ScienceIII).docx.pdf'
import SciW1 from '../assets/ProfessionalSummary/LP-Science_Week1.pdf'
import SciW2 from '../assets/ProfessionalSummary/LP-Science_Week2.pdf'
import SciW3 from '../assets/ProfessionalSummary/LP-Science_Week3.pdf'
import SciW4 from '../assets/ProfessionalSummary/LP-Science_Week4.pdf'
import SciW5 from '../assets/ProfessionalSummary/LP-Science_Week5.pdf'
import CareW1 from '../assets/ProfessionalSummary/LP_CareSkillsW1.pdf'
import CareW1Q4 from '../assets/ProfessionalSummary/LP_CareSkillsW1Q4.pdf'
import CareW2 from '../assets/ProfessionalSummary/LP_CareSkillsW2 (1).pdf'
import CareW2Q4 from '../assets/ProfessionalSummary/LP_CareSkillsW2Q4.pdf'
import CareW3Q4 from '../assets/ProfessionalSummary/LP_CareSkillsW3Q4.pdf'
import EngW1 from '../assets/ProfessionalSummary/LP_EnglishW1.pdf'
import EngW1Q4 from '../assets/ProfessionalSummary/LP_EnglishW1Q4.pdf'
import EngW2Q4 from '../assets/ProfessionalSummary/LP_EnglishW2Q4.pdf'
import EngW3Q4 from '../assets/ProfessionalSummary/LP_EnglishW3Q4.pdf'
import EngW4Q4 from '../assets/ProfessionalSummary/LP_EnglishW4Q4.pdf'
import MathW1W2Q4 from '../assets/ProfessionalSummary/LP_MathematicsW1and2Q4.pdf'
import LP_ScienceW1 from '../assets/ProfessionalSummary/_LP_ScienceW1.pdf'

const profileDocs = [
    { label: 'Curriculum Vitae', icon: '📄', pdf: Resume, desc: 'Teaching background, certifications & experience.' },
    { label: 'CBAR Philippines', icon: '🔬', pdf: Cbar,   desc: 'Community-Based Action Research internship report.' },
]

const lessonPlans = [
    //{ label: 'CBAR Internship',              subject: 'Research',    icon: '🔬', pdf: CBAR },
    { label: 'Final Demo – LP West',         subject: 'Demo',        icon: '🎓', pdf: FinalDemo },
    { label: 'Final Demo – Science III',     subject: 'Science',     icon: '🧪', pdf: GallanoLP },
    { label: 'Science – Week 1',             subject: 'Science',     icon: '🧪', pdf: SciW1 },
    { label: 'Science – Week 2',             subject: 'Science',     icon: '🧪', pdf: SciW2 },
    { label: 'Science – Week 3',             subject: 'Science',     icon: '🧪', pdf: SciW3 },
    { label: 'Science – Week 4',             subject: 'Science',     icon: '🧪', pdf: SciW4 },
    { label: 'Science – Week 5',             subject: 'Science',     icon: '🧪', pdf: SciW5 },
    {label:  'West Science - Week 1' ,       subject: 'Science',     icon: '🧪', pdf: SciW5},
    { label: 'Care Skills – Week 1',         subject: 'Care Skills', icon: '🤲', pdf: CareW1 },
    { label: 'Care Skills – Week 1 Q4',     subject: 'Care Skills', icon: '🤲', pdf: CareW1Q4 },
    { label: 'Care Skills – Week 2',         subject: 'Care Skills', icon: '🤲', pdf: CareW2 },
    { label: 'Care Skills – Week 2 Q4',     subject: 'Care Skills', icon: '🤲', pdf: CareW2Q4 },
    { label: 'Care Skills – Week 3 Q4',     subject: 'Care Skills', icon: '🤲', pdf: CareW3Q4 },
    { label: 'English – Week 1',             subject: 'English',     icon: '📖', pdf: EngW1 },
    { label: 'English – Week 1 Q4',         subject: 'English',     icon: '📖', pdf: EngW1Q4 },
    { label: 'English – Week 2 Q4',         subject: 'English',     icon: '📖', pdf: EngW2Q4 },
    { label: 'English – Week 3 Q4',         subject: 'English',     icon: '📖', pdf: EngW3Q4 },
    { label: 'English – Week 4 Q4',         subject: 'English',     icon: '📖', pdf: EngW4Q4 },
    { label: 'Mathematics – Week 1 & 2 Q4', subject: 'Mathematics', icon: '📐', pdf: MathW1W2Q4 }
]
---

<Layout>
    <AppHeader />

    <section class="py-20">
        <div class="max-w-4xl mx-auto px-4">

            <!-- Page title -->
            <div class="text-center mb-15">
                <h1 class="title text-5xl font-black">Documents</h1>
                <p class="mt-3 text-gray-500">Click any document to preview it.</p>
            </div>

            <!-- Profile docs -->
            <div class="mb-10">
                <h2 class="text-xs font-black uppercase tracking-widest mb-4 opacity-40">Profile</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 border-t-3 border-l-3 border-black">
                    {profileDocs.map((doc) => (
                            <div
                                    class="doc-card p-6 flex flex-col gap-3 cursor-pointer transition-colors hover:bg-[var(--yellow)] border-r-3 border-b-3 border-black"
                                    data-pdf={doc.pdf}
                                    data-label={doc.label}
                            >
                                <div class="flex justify-between items-center">
                                    <span class="text-xs font-bold uppercase tracking-widest border-2 border-black px-2 py-0.5">PDF</span>
                                    <span class="text-2xl">{doc.icon}</span>
                                </div>
                                <h3 class="font-black text-xl">{doc.label}</h3>
                                <p class="text-sm text-gray-500">{doc.desc}</p>
                                <span class="text-sm font-bold mt-auto">View ↓</span>
                            </div>
                    ))}
                </div>
            </div>

            <!-- Lesson Plans -->
            <div class="mb-10">
                <h2 class="text-xs font-black uppercase tracking-widest mb-4 opacity-40">Lesson Plans</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 border-t-3 border-l-3 border-black">
                    {lessonPlans.map((doc) => (
                            <div
                                    class="doc-card p-5 flex flex-col gap-2 cursor-pointer transition-colors hover:bg-[var(--yellow)] border-r-3 border-b-3 border-black"
                                    data-pdf={doc.pdf}
                                    data-label={doc.label}
                            >
                                <div class="flex justify-between items-center">
                                    <span class="text-xs font-bold uppercase tracking-widest border-2 border-black px-2 py-0.5">{doc.subject}</span>
                                    <span class="text-xl">{doc.icon}</span>
                                </div>
                                <h3 class="font-black text-base leading-snug">{doc.label}</h3>
                                <span class="text-xs font-bold mt-auto">View ↓</span>
                            </div>
                    ))}
                </div>
            </div>

            <!-- Viewer -->
            <div id="doc-viewer" class="hidden border-3 border-black mt-2">
                <div class="flex items-center justify-between px-5 py-3 bg-black text-white">
                    <span id="doc-viewer-label" class="font-bold text-sm italic"></span>
                    <div class="flex items-center gap-4">
                        <a id="doc-viewer-download" href="#" download target="_blank" class="text-[var(--yellow)] text-xs font-bold hover:underline">↓ Download</a>
                        <button id="doc-viewer-close" class="text-xs border border-white/30 px-3 py-1 rounded-full hover:bg-white/10 transition-colors">✕ Close</button>
                    </div>
                </div>
                <iframe id="doc-iframe" src="" title="Document Viewer" class="w-full h-[75vh] block border-none"></iframe>
            </div>

        </div>
    </section>

    <AppFooter />
</Layout>

<script>
    const cards  = document.querySelectorAll('.doc-card')
    const viewer = document.getElementById('doc-viewer')!
    const iframe = document.getElementById('doc-iframe') as HTMLIFrameElement
    const label  = document.getElementById('doc-viewer-label')!
    const dl     = document.getElementById('doc-viewer-download') as HTMLAnchorElement
    const close  = document.getElementById('doc-viewer-close')!

    let active: Element | null = null

    cards.forEach(card => {
        card.addEventListener('click', () => {
            const pdf       = card.getAttribute('data-pdf')!
            const cardLabel = card.getAttribute('data-label')!

            // Same card clicked → close
            if (active === card && !viewer.classList.contains('hidden')) {
                viewer.classList.add('hidden')
                iframe.src = ''
                active = null
                return
            }

            iframe.src        = pdf
            label.textContent = cardLabel
            dl.href           = pdf
            viewer.classList.remove('hidden')
            active = card

            setTimeout(() => viewer.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100)
        })
    })

    close.addEventListener('click', () => {
        viewer.classList.add('hidden')
        iframe.src = ''
        active = null
    })
</script>